{
  "matrix_rule_react": {
    "description": "Matrix 规则 React",
    "type": "object",
    "items": {
      "enable": {
        "description": "启用条件 Reaction",
        "type": "bool",
        "hint": "收到 @机器人或 AstrBot 确认有效的唤醒前缀消息时发送 reaction",
        "default": false
      },
      "emojis": {
        "description": "React 列表",
        "type": "list",
        "items": { "type": "string" },
        "hint": "例如 ['👍', '🤔', '✍️']；会忽略空值和重复项，也支持 mxc:// reaction key",
        "default": ["🤗", "🐟", "🍞"]
      },
      "rules": {
        "description": "动态 Reaction 规则",
        "type": "template_list",
        "hint": "按列表顺序匹配，首个匹配的规则生效；可通过 /matrix rules react 管理",
        "default": [],
        "templates": {
          "reaction_rule": {
            "name": "Matrix Reaction Rule",
            "items": {
              "selection": {
                "description": "Reaction 选取模式",
                "type": "string",
                "options": ["fixed", "random"],
                "default": "fixed"
              },
              "reactions": {
                "description": "Reaction 列表",
                "type": "list",
                "items": { "type": "string" },
                "hint": "fixed 模式使用第一项，random 模式随机选取",
                "default": ["👍"]
              },
              "conditions": {
                "description": "匹配条件数组",
                "type": "list",
                "hint": "所有条件均匹配时规则才生效；通过 /matrix rules react add 管理",
                "invisible": true,
                "items": {
                  "match_type": {
                    "description": "匹配类型",
                    "type": "string",
                    "options": [
                      "keyword",
                      "regex",
                      "user_id",
                      "bot_id",
                      "group_id",
                      "message_type"
                    ],
                    "default": "keyword"
                  },
                  "pattern": {
                    "description": "匹配内容",
                    "type": "string",
                    "hint": "关键字、正则、用户/机器人/群组 ID 或消息类型",
                    "default": ""
                  }
                },
                "default": []
              }
            }
          }
        }
      }
    }
  }
}
